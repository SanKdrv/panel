# ============ Ports ============
BACKEND_PORT=8001
FRONTEND_PORT=5173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ============ Backend ============
BACKEND_HOST=0.0.0.0
LOG_LEVEL=INFO
HTTP_ACCESS_LOG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Публичный URL, под которым админка открывается в браузере.
# Используется Grafana'ой для генерации внутренних ссылок (root_url).
# В проде укажи реальный IP/домен сервера и порт.
PANEL_PUBLIC_URL=http://localhost:5173

# Admin login (used by /api/auth/login). Like Grafana's pattern.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Session JWT signing key (change in prod)
SESSION_SECRET=replace-me-with-32-byte-random-string
SESSION_TTL_HOURS=12

# ============ RAG system API ============
RAG_BACKEND_URL=http://rag-api:8000
RAG_API_SECRET=replace-me-with-real-secret
RAG_TIMEOUT_SECONDS=30

# ============ Quality evaluation ============
QUALITY_GOLD_DATASET_PATH=/app/app/data/gold_dataset.json
QUALITY_EMBEDDING_URL=http://embedding-server:11434
QUALITY_EMBEDDING_MODEL=bge-m3
QUALITY_JUDGE_URL=http://llm-server:11434
QUALITY_JUDGE_MODEL=command-r7b-arabic

# ============ node_exporter на трёх RAG-серверах ============
RAG_EXPORTER_TARGET=host.docker.internal:9100
OLLAMA_EXPORTER_TARGET=host.docker.internal:9100
EMBEDDING_EXPORTER_TARGET=host.docker.internal:9100
RAG_SERVER_NAME=rag-core
OLLAMA_SERVER_NAME=ollama-llm
EMBEDDING_SERVER_NAME=embedding-worker

# ============ Grafana embed ============
# Относительные URL: Grafana проксируется через nginx фронта под /grafana/.
# Работают с любого хоста — браузер сам подставляет origin.
# panelId: 9 = тренд качества, 1/2/3/4 = CPU/Memory/Disk/Network серверов.
GRAFANA_EMBED_URL=/grafana/d-solo/rag-ops/rag-operations?orgId=1&theme=light&panelId=9&refresh=30s
GRAFANA_DASHBOARD_URL=/grafana/d/rag-ops/rag-operations
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
